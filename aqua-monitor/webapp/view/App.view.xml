<mvc:View
    controllerName="com.gilgar.aquamonitor.controller.App"
    displayBlock="true"
    xmlns:mvc="sap.ui.core.mvc"
    xmlns:core="sap.ui.core"
    xmlns:app="http://schemas.sap.com/sapui5/extension/sap.ui.core.CustomData/1"
    xmlns="sap.m">

    <App id="app">
        <Page id="page" title="{i18n>appTitle}">
            <headerContent>
                <Button id="btnRefresh" icon="sap-icon://refresh" tooltip="{i18n>refresh}" press=".onRefresh"/>
            </headerContent>
            <content>
                <IconTabBar id="itb" class="sapUiResponsiveContentPadding" expandable="false">
                    <items>

                        <!-- ================= FEEDING ================= -->
                        <IconTabFilter id="tabFeeding" icon="sap-icon://nutrition-activity"
                                       text="{i18n>tabFeeding}" count="{data>/counts/Feeding}" iconColor="Positive">
                            <OverflowToolbar design="Transparent" class="sapUiTinyMarginBottom">
                                <DateRangeSelection id="fDateFeeding" width="16rem" placeholder="{i18n>filterDate}"/>
                                <Input id="fBatchFeeding" width="10rem" placeholder="{i18n>filterBatch}" submit=".onGo" app:tab="Feeding"/>
                                <Input id="fExtraFeeding" width="10rem" placeholder="{i18n>colTank}" submit=".onGo" app:tab="Feeding"/>
                                <Select id="fStatusFeeding" width="9rem">
                                    <items>
                                        <core:Item key="ALL" text="{i18n>statusAll}"/>
                                        <core:Item key="OK" text="{i18n>statusOk}"/>
                                        <core:Item key="ERR" text="{i18n>statusError}"/>
                                    </items>
                                </Select>
                                <ToolbarSpacer/>
                                <Button text="{i18n>go}" type="Emphasized" press=".onGo" app:tab="Feeding"/>
                                <Button text="{i18n>clear}" press=".onClear" app:tab="Feeding"/>
                            </OverflowToolbar>
                            <Table id="tblFeeding" inset="false" growing="true" growingThreshold="25" sticky="ColumnHeaders,HeaderToolbar"
                                   busy="{data>/busy/Feeding}" busyIndicatorDelay="0"
                                   items="{data>/Feeding}">
                                <headerToolbar>
                                    <OverflowToolbar>
                                        <Title text="{i18n>tabFeeding}" level="H2"/>
                                    </OverflowToolbar>
                                </headerToolbar>
                                <columns>
                                    <Column><Text text="{i18n>colDate}"/></Column>
                                    <Column><Text text="{i18n>colTank}"/></Column>
                                    <Column><Text text="{i18n>colBatch}"/></Column>
                                    <Column hAlign="End"><Text text="{i18n>colQuantity}"/></Column>
                                    <Column minScreenWidth="Tablet" demandPopin="true"><Text text="{i18n>colFeedCode}"/></Column>
                                    <Column minScreenWidth="Tablet" demandPopin="true"><Text text="{i18n>colProdOrder}"/></Column>
                                    <Column minScreenWidth="Desktop" demandPopin="true"><Text text="{i18n>colMatDoc}"/></Column>
                                    <Column hAlign="Center"><Text text="{i18n>colStatus}"/></Column>
                                </columns>
                                <items>
                                    <ColumnListItem vAlign="Middle">
                                        <cells>
                                            <Text text="{parts: [{path: 'data>EntryDateTime'}, {path: 'data>CreatedAt'}], formatter: '.formatEntryDate'}"/>
                                            <Text text="{data>Tank}"/>
                                            <ObjectIdentifier title="{data>Batch}"/>
                                            <ObjectNumber number="{data>Quantity}"/>
                                            <Text text="{= ${data>ERPFeedCode} || ${data>AMFeedCode} }"/>
                                            <Text text="{data>ProductionOrder}"/>
                                            <Text text="{data>MaterialDocumentNumber}"/>
                                            <ObjectStatus text="{= ${data>Success} ? ${i18n>statusOk} : ${i18n>statusError} }"
                                                          state="{= ${data>Success} ? 'Success' : 'Error' }"
                                                          tooltip="{data>ErrorText}"/>
                                        </cells>
                                    </ColumnListItem>
                                </items>
                            </Table>
                        </IconTabFilter>

                        <!-- ================= DEAD FISH ================= -->
                        <IconTabFilter id="tabDeadFish" icon="sap-icon://alert"
                                       text="{i18n>tabDeadFish}" count="{data>/counts/DeadFish}" iconColor="Negative">
                            <OverflowToolbar design="Transparent" class="sapUiTinyMarginBottom">
                                <DateRangeSelection id="fDateDeadFish" width="16rem" placeholder="{i18n>filterDate}"/>
                                <Input id="fBatchDeadFish" width="10rem" placeholder="{i18n>filterBatch}" submit=".onGo" app:tab="DeadFish"/>
                                <Input id="fExtraDeadFish" width="10rem" placeholder="{i18n>colUnit}" submit=".onGo" app:tab="DeadFish"/>
                                <Select id="fStatusDeadFish" width="9rem">
                                    <items>
                                        <core:Item key="ALL" text="{i18n>statusAll}"/>
                                        <core:Item key="OK" text="{i18n>statusOk}"/>
                                        <core:Item key="ERR" text="{i18n>statusError}"/>
                                    </items>
                                </Select>
                                <ToolbarSpacer/>
                                <Button text="{i18n>go}" type="Emphasized" press=".onGo" app:tab="DeadFish"/>
                                <Button text="{i18n>clear}" press=".onClear" app:tab="DeadFish"/>
                            </OverflowToolbar>
                            <Table id="tblDeadFish" inset="false" growing="true" growingThreshold="25" sticky="ColumnHeaders,HeaderToolbar"
                                   busy="{data>/busy/DeadFish}" busyIndicatorDelay="0"
                                   items="{data>/DeadFish}">
                                <headerToolbar>
                                    <OverflowToolbar>
                                        <Title text="{i18n>tabDeadFish}" level="H2"/>
                                    </OverflowToolbar>
                                </headerToolbar>
                                <columns>
                                    <Column><Text text="{i18n>colDate}"/></Column>
                                    <Column><Text text="{i18n>colUnit}"/></Column>
                                    <Column><Text text="{i18n>colBatch}"/></Column>
                                    <Column><Text text="{i18n>colCause}"/></Column>
                                    <Column hAlign="End"><Text text="{i18n>colQuantity}"/></Column>
                                    <Column minScreenWidth="Tablet" demandPopin="true"><Text text="{i18n>colProdOrder}"/></Column>
                                    <Column minScreenWidth="Desktop" demandPopin="true"><Text text="{i18n>colMatDoc}"/></Column>
                                    <Column hAlign="Center"><Text text="{i18n>colStatus}"/></Column>
                                </columns>
                                <items>
                                    <ColumnListItem vAlign="Middle">
                                        <cells>
                                            <Text text="{parts: [{path: 'data>EntryDateTime'}, {path: 'data>CreatedAt'}], formatter: '.formatEntryDate'}"/>
                                            <Text text="{data>Unit}"/>
                                            <ObjectIdentifier title="{data>Batch}"/>
                                            <Text text="{data>Cause}"/>
                                            <ObjectNumber number="{data>Quantity}"/>
                                            <Text text="{data>ProductionOrder}"/>
                                            <Text text="{data>MaterialDocumentNumber}"/>
                                            <ObjectStatus text="{= ${data>Success} ? ${i18n>statusOk} : ${i18n>statusError} }"
                                                          state="{= ${data>Success} ? 'Success' : 'Error' }"
                                                          tooltip="{data>ErrorText}"/>
                                        </cells>
                                    </ColumnListItem>
                                </items>
                            </Table>
                        </IconTabFilter>

                        <!-- ================= TRANSFER ================= -->
                        <IconTabFilter id="tabTransfer" icon="sap-icon://shipping-status"
                                       text="{i18n>tabTransfer}" count="{data>/counts/Transfer}" iconColor="Critical">
                            <OverflowToolbar design="Transparent" class="sapUiTinyMarginBottom">
                                <DateRangeSelection id="fDateTransfer" width="16rem" placeholder="{i18n>filterDate}"/>
                                <Input id="fBatchTransfer" width="10rem" placeholder="{i18n>filterBatch}" submit=".onGo" app:tab="Transfer"/>
                                <Input id="fExtraTransfer" width="10rem" placeholder="{i18n>colWayBill}" submit=".onGo" app:tab="Transfer"/>
                                <Select id="fStatusTransfer" width="9rem">
                                    <items>
                                        <core:Item key="ALL" text="{i18n>statusAll}"/>
                                        <core:Item key="OK" text="{i18n>statusOk}"/>
                                        <core:Item key="ERR" text="{i18n>statusError}"/>
                                    </items>
                                </Select>
                                <ToolbarSpacer/>
                                <Button text="{i18n>go}" type="Emphasized" press=".onGo" app:tab="Transfer"/>
                                <Button text="{i18n>clear}" press=".onClear" app:tab="Transfer"/>
                            </OverflowToolbar>
                            <Table id="tblTransfer" inset="false" growing="true" growingThreshold="25" sticky="ColumnHeaders,HeaderToolbar"
                                   busy="{data>/busy/Transfer}" busyIndicatorDelay="0"
                                   items="{data>/Transfer}">
                                <headerToolbar>
                                    <OverflowToolbar>
                                        <Title text="{i18n>tabTransfer}" level="H2"/>
                                    </OverflowToolbar>
                                </headerToolbar>
                                <columns>
                                    <Column><Text text="{i18n>colDate}"/></Column>
                                    <Column><Text text="{i18n>colWayBill}"/></Column>
                                    <Column><Text text="{i18n>colFromStore}"/></Column>
                                    <Column><Text text="{i18n>colToStore}"/></Column>
                                    <Column minScreenWidth="Tablet" demandPopin="true"><Text text="{i18n>colItem}"/></Column>
                                    <Column hAlign="End"><Text text="{i18n>colQuantity}"/></Column>
                                    <Column><Text text="{i18n>colBatch}"/></Column>
                                    <Column minScreenWidth="Desktop" demandPopin="true"><Text text="{i18n>colMatDoc}"/></Column>
                                    <Column hAlign="Center"><Text text="{i18n>colStatus}"/></Column>
                                </columns>
                                <items>
                                    <ColumnListItem vAlign="Middle">
                                        <cells>
                                            <Text text="{parts: [{path: 'data>EntryDateTime'}, {path: 'data>CreatedAt'}], formatter: '.formatEntryDate'}"/>
                                            <ObjectIdentifier title="{data>WayBillCode}"/>
                                            <Text text="{data>ERPStoreCode}"/>
                                            <Text text="{data>ERPDestinationStoreCode}"/>
                                            <Text text="{data>ERPItemCode}"/>
                                            <ObjectNumber number="{data>Qty}"/>
                                            <Text text="{data>Batch}"/>
                                            <Text text="{data>MaterialDocumentNumber}"/>
                                            <ObjectStatus text="{= ${data>Success} ? ${i18n>statusOk} : ${i18n>statusError} }"
                                                          state="{= ${data>Success} ? 'Success' : 'Error' }"
                                                          tooltip="{data>ErrorText}"/>
                                        </cells>
                                    </ColumnListItem>
                                </items>
                            </Table>
                        </IconTabFilter>

                        <!-- ================= HARVEST ================= -->
                        <IconTabFilter id="tabHarvest" icon="sap-icon://inventory"
                                       text="{i18n>tabHarvest}" count="{data>/counts/Harvest}" iconColor="Default">
                            <OverflowToolbar design="Transparent" class="sapUiTinyMarginBottom">
                                <DateRangeSelection id="fDateHarvest" width="16rem" placeholder="{i18n>filterDate}"/>
                                <Input id="fBatchHarvest" width="10rem" placeholder="{i18n>filterBatch}" submit=".onGo" app:tab="Harvest"/>
                                <Input id="fExtraHarvest" width="10rem" placeholder="{i18n>colCageLot}" submit=".onGo" app:tab="Harvest"/>
                                <Select id="fStatusHarvest" width="9rem">
                                    <items>
                                        <core:Item key="ALL" text="{i18n>statusAll}"/>
                                        <core:Item key="OK" text="{i18n>statusOk}"/>
                                        <core:Item key="ERR" text="{i18n>statusError}"/>
                                    </items>
                                </Select>
                                <ToolbarSpacer/>
                                <Button text="{i18n>go}" type="Emphasized" press=".onGo" app:tab="Harvest"/>
                                <Button text="{i18n>clear}" press=".onClear" app:tab="Harvest"/>
                            </OverflowToolbar>
                            <Table id="tblHarvest" inset="false" growing="true" growingThreshold="25" sticky="ColumnHeaders,HeaderToolbar"
                                   busy="{data>/busy/Harvest}" busyIndicatorDelay="0"
                                   items="{data>/Harvest}">
                                <headerToolbar>
                                    <OverflowToolbar>
                                        <Title text="{i18n>tabHarvest}" level="H2"/>
                                    </OverflowToolbar>
                                </headerToolbar>
                                <columns>
                                    <Column><Text text="{i18n>colDate}"/></Column>
                                    <Column><Text text="{i18n>colCageLot}"/></Column>
                                    <Column><Text text="{i18n>colUnit}"/></Column>
                                    <Column><Text text="{i18n>colBatch}"/></Column>
                                    <Column minScreenWidth="Tablet" demandPopin="true"><Text text="{i18n>colSite}"/></Column>
                                    <Column minScreenWidth="Tablet" demandPopin="true"><Text text="{i18n>colProdOrder}"/></Column>
                                    <Column minScreenWidth="Desktop" demandPopin="true"><Text text="{i18n>colConfirmation}"/></Column>
                                    <Column hAlign="Center"><Text text="{i18n>colStatus}"/></Column>
                                </columns>
                                <items>
                                    <ColumnListItem vAlign="Middle">
                                        <cells>
                                            <Text text="{parts: [{path: 'data>EntryDateTime'}, {path: 'data>CreatedAt'}], formatter: '.formatEntryDate'}"/>
                                            <ObjectIdentifier title="{data>CageLotID}"/>
                                            <Text text="{data>Unit}"/>
                                            <Text text="{data>Batch}"/>
                                            <Text text="{= ${data>ERPSiteCode} || ${data>AMSiteCode} }"/>
                                            <Text text="{data>ProductionOrder}"/>
                                            <Text text="{data>ProdOrderConfirmation}"/>
                                            <ObjectStatus text="{= ${data>Success} ? ${i18n>statusOk} : ${i18n>statusError} }"
                                                          state="{= ${data>Success} ? 'Success' : 'Error' }"
                                                          tooltip="{data>ErrorText}"/>
                                        </cells>
                                    </ColumnListItem>
                                </items>
                            </Table>
                        </IconTabFilter>

                    </items>
                </IconTabBar>
            </content>
        </Page>
    </App>
</mvc:View>
